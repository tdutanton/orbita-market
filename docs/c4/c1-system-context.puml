@startuml C1 - System Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title C1 — System Context: OrbitaMarket

Person(operator, "Оператор ДЗЗ", "Заказывает снимки и данные ДЗЗ")
Person(analyst, "Аналитик", "Просматривает и анализирует заказанные данные")
Person(admin, "Администратор", "Управляет аккаунтами и настройками системы")

System_Boundary(orbita, "OrbitaMarket") {
  System(apiGateway, "API Gateway", "Единая точка входа, маршрутизация запросов")
}

Rel(operator, apiGateway, "Заказы, оплата", "HTTPS")
Rel(analyst, apiGateway, "Просмотр данных, отчёты", "HTTPS")
Rel(admin, apiGateway, "Управление, администрирование", "HTTPS")

SHOW_LEGEND()
@enduml
